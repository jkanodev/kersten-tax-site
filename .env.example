# Copy to .env locally. Never commit real secrets.

# SQLite (local/dev). Path is relative to prisma/schema.prisma → prisma/dev.db
DATABASE_URL="file:./dev.db"

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
# Production: canonical site URL (also used for OAuth/email callbacks if you add them later)
AUTH_URL="http://localhost:3000"

# Optional: first-time seed password for admin login
SEED_ADMIN_PASSWORD="ChangeMeSoon!123"
