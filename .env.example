# Copy to `.env` for local development. Never commit real secrets.

# ─── Database (PostgreSQL required; same as production engine) ─────────────
# 1) Start local DB:  docker compose up -d
# 2) Use this URL (port 5433 maps to Postgres in docker-compose.yml):
DATABASE_URL="postgresql://kersten:kersten@localhost:5433/kersten?schema=public"
#
# Production / Neon: paste the pooled connection string from your host, e.g.
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ─── NextAuth ──────────────────────────────────────────────────────────────
AUTH_SECRET="replace-with-long-random-string-openssl-rand-base64-32"
# Local:
AUTH_URL="http://localhost:3000"
# Production (Vercel):
# AUTH_URL="https://www.kerstencrawford.com"

# ─── Optional: prisma seed (first-run admin only) ──────────────────────────
SEED_ADMIN_PASSWORD="ChangeMeSoon!123"

# ─── Admin bootstrap script (production emergency) ─────────────────────────
# ALLOW_ADMIN_BOOTSTRAP=1
# BOOTSTRAP_ADMIN_PASSWORD="ChangeMeSoon!123"
